{
  "name": "lunor-cli",
  "version": "1.0.0",
  "description": "LUNOR KIT command center for AI model management and skill orchestration",
  "type": "module",
  "bin": {
    "lunor": "./dist/index.js"
  },
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "build": "tsc && chmod +x dist/index.js",
    "test": "vitest",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["cli", "ai", "model-switcher", "tui"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "commander": "^12.0.0",
    "picocolors": "^1.1.1",
    "@clack/prompts": "^0.8.2",
    "ora": "^8.0.1",
    "ink": "^4.4.1",
    "react": "^18.2.0",
    "zod": "^3.24.2",
    "axios": "^1.6.5",
    "axios-retry": "^4.0.0",
    "better-sqlite3": "^12.2.0",
    "node-cache": "^5.1.2",
    "fuse.js": "^7.0.0",
    "js-yaml": "^4.1.0",
    "date-fns": "^3.2.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.5",
    "@types/better-sqlite3": "^7.6.12",
    "@types/js-yaml": "^4.0.9",
    "@types/react": "^18.2.48",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "vitest": "^1.2.1",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.19.1",
    "@typescript-eslint/parser": "^6.19.1"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
