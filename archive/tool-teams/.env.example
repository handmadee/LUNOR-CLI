# Server Configuration
PORT=3000
NODE_ENV=development

# Security - CHANGE THIS IN PRODUCTION!
ENCRYPTION_KEY=your-32-character-encryption-key

# Database - SQLite (Legacy, for migration only)
DATABASE_PATH=./src/data/toolteams.db

# MongoDB Configuration (Primary Database)
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=yourApp
MONGODB_POOL_SIZE=10

# Microsoft Teams API
MS_TEAMS_API_BASE=https://flw.teams.cloud.microsoft
MS_TEAMS_API_VERSION=20

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=8451500903:AAGy4HleFa1H4vEOADtgHpvBpcMJ4ziQvOk
TELEGRAM_CHAT_ID=your-chat-id
TELEGRAM_ENABLED=true

# Scheduler Configuration (24h format)
SCHEDULER_MORNING_IN=08:00
SCHEDULER_MORNING_OUT=12:00
SCHEDULER_AFTERNOON_IN=13:30
SCHEDULER_AFTERNOON_OUT=17:30

# Leantime Integration (Optional)
# Default Leantime instance URL (can be overridden per user)
LEANTIME_URL=https://project.hilab.cloud
# Default credentials (for system-level operations, optional)
LEANTIME_EMAIL=your-email@example.com
LEANTIME_PASSWORD=your-password

# MS Teams Default Credentials (for auto re-login on token expiration)
MS_TEAMS_EMAIL=your-email@company.com
MS_TEAMS_PASSWORD=your-password
MS_TEAMS_TEAM_ID=TEAM_your-team-id-here
